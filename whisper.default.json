{
  "profile": "fast-local-stt",
  "description": "Fast local STT defaults for Twitch cohost",
  "stt_enabled": true,
  "stt_binary_path": "whisper-cli",
  "stt_model_path_candidates": [
    "~/.cache/whisper.cpp/ggml-tiny.en.bin",
    "~/.cache/whisper.cpp/ggml-base.en.bin",
    "~/.cache/whisper.cpp/ggml-small.en.bin",
    "~/models/ggml-base.en.bin",
    "~/models/whisper/ggml-base.en.bin",
    "./models/ggml-tiny.en.bin",
    "./models/ggml-base.en.bin",
    "./models/whisper/ggml-base.en.bin"
  ],
  "recommended": {
    "fastest": "ggml-tiny.en.bin",
    "better_accuracy": "ggml-small.en.bin"
  },
  "notes": [
    "tiny.en is the fastest default for live streamer speech",
    "small.en is slower but more accurate",
    "Auto Setup STT scans these paths and applies first existing model"
  ]
}
